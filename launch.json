{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit Debug",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "${file}"],
      "python": "${workspaceFolder}/venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}